{
  "name": "ds-language-server",
  "version": "0.1.0",
  "description": "Language Server for design systems — IntelliSense for components, tokens, and utility classes with lifecycle-aware deprecation diagnostics.",
  "author": "Magnus Fredlundh",
  "license": "MIT",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "ds-language-server": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/server.js --stdio",
    "test": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.0.8",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
