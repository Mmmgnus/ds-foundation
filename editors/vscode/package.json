{
  "name": "ds-language-server",
  "displayName": "Design System Language Server",
  "description": "IntelliSense for design system components, tokens, and utility classes with lifecycle-aware deprecation diagnostics.",
  "version": "0.1.0",
  "publisher": "ds-foundation",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mmmgnus/ds-foundation"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": ["Programming Languages", "Linters"],
  "keywords": [
    "design system",
    "design tokens",
    "web components",
    "custom elements",
    "css",
    "intellisense",
    "deprecation"
  ],
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:css",
    "onLanguage:scss",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Design System Language Server",
      "properties": {
        "dsLanguageServer.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Design System Language Server."
        },
        "dsLanguageServer.serverPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the LSP server.js. If empty, uses the bundled server."
        },
        "dsLanguageServer.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace communication between VS Code and the language server."
        }
      }
    }
  },
  "scripts": {
    "bundle-server": "esbuild ../../src/server.ts --bundle --outfile=server/server.js --format=cjs --platform=node --minify",
    "package": "npm run bundle-server && vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "@vscode/vsce": "^2.26.0"
  }
}
