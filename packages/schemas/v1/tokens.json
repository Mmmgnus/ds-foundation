{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ds.foundation/schemas/v1/tokens.json",
  "title": "Design System Tokens Manifest",
  "description": "Schema for design token manifests consumed by the DS Language Server and documentation tools.",
  "type": "object",
  "required": ["schemaVersion", "tokens"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": {
      "type": "string",
      "description": "Schema version (semver)"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp of when this manifest was generated"
    },
    "source": {
      "type": "object",
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "file": { "type": "string" },
              "mode": { "type": "string" }
            }
          }
        }
      }
    },
    "counts": {
      "type": "object",
      "properties": {
        "total": { "type": "integer" },
        "byGroup": { "type": "object", "additionalProperties": { "type": "integer" } },
        "byCategory": { "type": "object", "additionalProperties": { "type": "integer" } }
      }
    },
    "tokens": {
      "type": "array",
      "items": { "$ref": "#/definitions/Token" }
    }
  },
  "definitions": {
    "Token": {
      "type": "object",
      "required": ["id", "path", "group", "category", "cssVariable", "resolved"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Dot-separated token identifier (e.g. 'color.bg.primary')"
        },
        "path": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Token path segments"
        },
        "originalPath": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Original path before normalization"
        },
        "group": {
          "type": "string",
          "description": "Top-level grouping (Color, Border, Spacing, Typography, etc.)"
        },
        "category": {
          "type": "string",
          "description": "Sub-group within the group (Background, Radius, Scale, etc.)"
        },
        "subCategory": {
          "type": ["string", "null"],
          "description": "Optional further categorization"
        },
        "type": {
          "type": ["string", "null"],
          "description": "Token type (color, dimension, fontWeight, etc.)"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Human-readable description of the token's purpose"
        },
        "cssVariable": {
          "type": ["string", "null"],
          "description": "CSS custom property name (e.g. '--ds-color-primary')"
        },
        "resolved": {
          "type": "object",
          "description": "Resolved (computed) values per mode",
          "additionalProperties": {}
        },
        "modes": {
          "type": "object",
          "description": "Authored values per mode (may contain alias references)",
          "additionalProperties": {}
        },
        "aliasChain": {
          "description": "Token alias resolution chain for documentation",
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "deprecated": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/definitions/Deprecated" }
          ],
          "description": "Deprecation info, or null if not deprecated"
        },
        "visibility": {
          "type": "object",
          "properties": {
            "isComponent": {
              "type": "boolean",
              "description": "True if this token is scoped to a specific component"
            },
            "isPrimitive": {
              "type": "boolean",
              "description": "True if this is a primitive/base token (not for direct use)"
            }
          }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Arbitrary tags for filtering/categorization"
        },
        "sourceFiles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Source files this token was defined in"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "description": "Extensible metadata (Figma variable IDs, etc.)"
        }
      }
    },
    "Deprecated": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": {
          "type": "string",
          "description": "Human-readable deprecation reason and migration guidance"
        },
        "removal": {
          "type": "string",
          "description": "When the item will be removed. ISO date (2026-07-30), semver (4.0.0), or quarter (Q3-2026)"
        },
        "replacement": {
          "type": "string",
          "description": "Machine-readable replacement identifier (CSS variable name, token ID, etc.)"
        }
      }
    }
  }
}
