{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ds.foundation/schemas/v1/utilities.json",
  "title": "Design System Utilities Manifest",
  "description": "Schema for CSS utility class manifests consumed by the DS Language Server and documentation tools.",
  "type": "object",
  "required": ["schemaVersion", "categories"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": {
      "type": "string",
      "description": "Schema version (semver)"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp of when this manifest was generated"
    },
    "categories": {
      "type": "array",
      "items": { "$ref": "#/definitions/Category" }
    }
  },
  "definitions": {
    "Category": {
      "type": "object",
      "required": ["name", "classes"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable category name (e.g. 'Text Style – Heading')"
        },
        "description": {
          "type": "string",
          "description": "Category description for documentation"
        },
        "prefix": {
          "type": "string",
          "description": "Common class name prefix for this category (e.g. 'lf-text-heading-')"
        },
        "classes": {
          "type": "array",
          "items": { "$ref": "#/definitions/UtilityClass" }
        }
      }
    },
    "UtilityClass": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Full CSS class name (e.g. 'lf-text-heading-1')"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what the class does"
        },
        "properties": {
          "type": "object",
          "description": "CSS property-value pairs this class generates",
          "additionalProperties": { "type": "string" }
        },
        "tokens": {
          "type": "array",
          "description": "CSS custom properties (tokens) referenced by this class",
          "items": { "type": "string" }
        },
        "deprecated": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/definitions/Deprecated" }
          ],
          "description": "Deprecation info, or null if not deprecated"
        }
      }
    },
    "Deprecated": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": {
          "type": "string",
          "description": "Human-readable deprecation reason and migration guidance"
        },
        "removal": {
          "type": "string",
          "description": "When the item will be removed. ISO date (2026-07-30), semver (4.0.0), or quarter (Q3-2026)"
        },
        "replacement": {
          "type": "string",
          "description": "Machine-readable replacement (class name to use instead)"
        }
      }
    }
  }
}
